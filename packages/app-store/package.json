{
  "name": "@calcom/app-store",
  "private": true,
  "sideEffects": false,
  "version": "0.0.0",
  "main": "./index.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./types/*",
        "./*"
      ]
    }
  },
  "files": [
    "components.ts"
  ],
  "scripts": {
    "build:types": "tsc --project tsconfig.build.json",
    "type-check": "tsc --pretty --noEmit",
    "type-check:ci": "tsc-absolute --pretty --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:report": "biome lint --reporter json . > ../../lint-results/app-store.json"
  },
  "dependencies": {
    "@calcom/dailyvideo": "portal:./dailyvideo",
    "@calcom/dayjs": "portal:../dayjs",
    "@calcom/features": "portal:../features",
    "@calcom/i18n": "portal:../i18n",
    "@calcom/lib": "portal:../lib",
    "@calcom/office365video": "portal:./office365video",
    "@calcom/ui": "portal:../ui",
    "@calcom/zoomvideo": "portal:./zoomvideo",
    "lodash": "4.18.1",
    "qs-stringify": "1.2.1",
    "react-i18next": "12.3.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "stripe": "^9.0.0 || ^15.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@calcom/testing": "portal:../testing",
    "@calcom/types": "portal:../types"
  }
}
